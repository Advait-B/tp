@startuml parser_main
hide footbox
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 80
skinparam style strictuml
skinparam SequenceGroupBodyBackgroundColor transparent
skinparam SequenceReferenceBackgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam SequenceBoxBackgroundColor transparent
skinparam sequenceParticipantBackgroundColor white
skinparam sequenceLifeLineBorderColor black

participant ":FlashCLI\n" as FlashCLI
participant "<<class>>\nParser" as Parser

FlashCLI -> Parser : parse(userInput)
activate Parser

Parser -> Parser : validateInput()
activate Parser
deactivate Parser

Parser -> Parser : validateCommandName()
activate Parser
deactivate Parser

|||

alt invalid input or invalid arguments
    Parser --> FlashCLI : exception
else valid input
    ref over Parser
        dispatch
    end ref

    Parser --> FlashCLI : Command
end

deactivate Parser
@enduml
